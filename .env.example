# ─── EcoManager — environment variables ───────────────────────────────
# Copy this file to `.env.local` for local dev, and add the same keys in
# Vercel → Project → Settings → Environment Variables for production.

# Supabase project URL (Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase service-role key (Project Settings → API → service_role secret).
# SERVER-ONLY — bypasses RLS. Never expose to the client / never prefix NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret used to sign/verify auth JWTs. Use a long random string, e.g.:
#   openssl rand -hex 64
JWT_SECRET=replace-with-a-long-random-secret

# Public base URL of the app (used for absolute links). No trailing slash.
# Local: http://localhost:3000  ·  Prod: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Integrations (optional — only needed for the related feature) ─────

# Protects the scheduled cron endpoint (Vercel Cron sends it as a Bearer token).
CRON_SECRET=replace-with-a-random-secret

# Google OAuth — required for the "Import Google Sheet" source.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NOEST carrier API — required for NOEST delivery dispatch.
NOEST_BASE_URL=https://api.noest-dz.com
NOEST_API_TOKEN=
NOEST_USER_GUID=

